---
layout: base
---

<main class="main container">

{% set collectionToUse = getTranslatedCollection %}
{% set stringsToUse = getTranslatedStrings %}

{%if collectionToUse %}
        {% if collectionToUse.introduction.length %}
            {% set intro = collectionToUse.introduction|first %}
            <section class="section" id="section-introduction">
                <h2 class="section__title">{{ intro.data.title }}</h2>
                <div class="lead p-summary" style="text-align: justify">
                    {{ intro.templateContent | safe }}
                </div>
            </section>
        {% endif %}

        <section class="section" id="section-experience">
            <h2 class="section__title">{{ stringsToUse.titles.experience }}</h2>
            {% set entries = collectionToUse.work %}
            {% set microformat = "p-experience" %}
            {% include "entrylist.njk" %}
        </section>

        <section class="section" id="section-education">
            <h2 class="section__title">{{ stringsToUse.titles.education }}</h2>
            {% set entries = collectionToUse.education %}
            {% set microformat = "p-education" %}
            {% include "entrylist.njk" %}
        </section>

    {% if author.skills or author.languages %}
        <div class="grid grid--2col">
            {% if author.skills %}
            <section class="section section--half" id="section-skills">
                <h2 class="section__title">{{ stringsToUse.titles.skills }}</h2>
                <ul class="bulletlist">
                {% for skill in author.skills %}
                    <li class="p-skill">{{ skill }}</li>
                {% endfor %}
                </ul>
            </section>
            {% endif %}

            {% if author.languages %}
            <section class="section section--half" id="section-languages">
                <h2 class="section__title">{{ stringsToUse.titles.languages }}</h2>
                <ul class="bulletlist">
                {% for language in author.languages %}
                    <li class="p-skill">{{ language.name }} ({{ language.level }})</li>
                {% endfor %}
                </ul>
            </section>
            {% endif %}
        </div>
    {% endif %}
{%endif%}
</main>